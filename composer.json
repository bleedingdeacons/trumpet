{
    "name": "bleeding-deacons/trumpet",
    "description": "An announcement management plugin for WordPress",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "authors": [
        {
            "name": "The Bleeding Deacons"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^9.6",
        "psr/container": "^2.0",
        "squizlabs/php_codesniffer": "^3.7",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Trumpet\\": "src/Trumpet/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": [
            "php build.php --clean"
        ],
        "build:production": [
            "php build.php --type=production --clean"
        ],
        "build:dev": [
            "php build.php --type=dev --clean"
        ],
        "compress": [
            "php build.php --type=production"
        ],
        "compress:dev": [
            "php build.php --type=dev"
        ],
        "clean": [
            "php build.php --clean-only"
        ],
        "version": [
            "@php -r \"$f='trumpet.php'; if(file_exists($f)){ $c=file_get_contents($f); if(preg_match('/Version:\\s*([0-9.]+)/',$c,$m)){ echo 'Current plugin version: '.$m[1].PHP_EOL; exit(0); }} echo 'Version not found'.PHP_EOL; exit(1);\""
        ],
        "help": [
            "php build.php --help"
        ],
        "test": [
            "phpunit"
        ],
        "test:coverage": [
            "phpunit --coverage-html coverage"
        ],
        "test:coverage-text": [
            "phpunit --coverage-text"
        ],
        "test:filter": [
            "phpunit --filter"
        ],
        "phpcs": [
            "phpcs --standard=PSR12 src"
        ],
        "phpcs:fix": [
            "phpcbf --standard=PSR12 src"
        ],
        "phpstan": "phpstan analyse --memory-limit=1G",
        "phpstan:baseline": [
            "phpstan analyse --memory-limit=1G src --level=5 --generate-baseline"
        ],
        "ci": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "build": "Clean build directory and create production-ready plugin archive",
        "build:production": "Clean and create production archive (explicit)",
        "build:dev": "Clean and create development archive with test files",
        "compress": "Create production archive without cleaning",
        "compress:dev": "Create development archive without cleaning",
        "clean": "Remove the build directory and all archives",
        "version": "Display the current plugin version from main file",
        "help": "Display detailed build script help and usage",
        "test": "Run PHPUnit tests",
        "test:coverage": "Run tests with HTML coverage report",
        "test:coverage-text": "Run tests with text coverage report",
        "test:filter": "Run filtered tests (usage: composer test:filter -- --filter=test_name)",
        "phpcs": "Check code style with PHP_CodeSniffer (PSR-12)",
        "phpcs:fix": "Automatically fix code style issues",
        "phpstan": "Run PHPStan static analysis",
        "phpstan:baseline": "Generate PHPStan baseline file",
        "ci": "Run all CI checks (code style, static analysis, tests)"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
